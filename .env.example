# Copy to .env and fill in. NEVER commit .env.

# CoinMarketCap AI Agent Hub
CMC_API_KEY=            # Pro REST quotes (free tier is enough; 1H candles are built in-agent)
CMC_MCP_API_KEY=        # MCP (Fear&Greed, derivatives, technicals); defaults to CMC_API_KEY

# Candle data
POLL_SECONDS=300        # quote-poll interval used to build 1H candles (live)
SEED_CACHE=0            # 1 = DEV warmup from local cache; 0 = pure CMC (for live)

# LLM veto (optional) — the LLM may ONLY veto an entry, never decide one
ANTHROPIC_API_KEY=      # empty = veto disabled (pure rule-based strategy)
VETO_MODEL=claude-haiku-4-5-20251001

# Trust Wallet Agent Kit (execution) — Access ID + HMAC set up by the installer into ~/.twak/
TWAK_LIVE=0             # 1 = send real transactions via TWAK; 0 = dry-run (default, safe)
TWAK_CLI=twak           # CLI binary (TWAK installer)
TWAK_CHAIN=bsc          # BNB Chain
TWAK_PASSWORD=          # wallet password for signing (if not using the OS keychain)

# BNB AI Agent SDK — ERC-8004 on-chain agent identity (optional, integration/identity.py)
BNB_NETWORK=bsc-testnet # gas-free identity registration on testnet
WALLET_PASSWORD=        # encrypts the bnbagent keystore (~/.bnbagent/wallets/)
AGENT_PRIVATE_KEY=      # agent wallet private key (first run only; then removable)
AGENT_ENDPOINT=         # public status URL advertised in the agent profile

# Capital & sizing
START_EQUITY=1000       # starting USD equity for paper accounting / risk target
